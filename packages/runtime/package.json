      "types": "./src/crossWorkbookLoader.ts",
      "default": "./src/crossWorkbookLoader.ts"
    },
    "./runtimeWorker": {
      "types": "./src/runtimeWorker.ts",
      "default": "./src/runtimeWorker.ts"
    },
    "./runtimeWorkerEntry": {
      "types": "./src/runtimeWorkerEntry.ts",
      "default": "./src/runtimeWorkerEntry.ts"
    },
    "./runDiff": {
      "types": "./src/runDiff.ts",
      "default": "./src/runDiff.ts"
    },
    "./blocks/*": {
      "svelte": "./src/blocks/*"
    },
    "./workbookContext": {
      "svelte": "./src/workbookContext.ts",
      "types": "./src/workbookContext.ts"
    }
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
