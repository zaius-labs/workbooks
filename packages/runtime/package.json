{
  "name": "@workbook/runtime",
  "version": "0.1.0",
  "description": "Workbook UI runtime — Svelte 5 components that render the workbook block tree. Used in live applications and embedded in portable .workbook files.",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/zaius-labs/workbooks.git",
    "directory": "packages/runtime"
  },
  "homepage": "https://github.com/zaius-labs/workbooks",
  "keywords": [
    "workbook",
    "svelte",
    "notebook",
    "document-format",
    "block-editor"
  ],
  "exports": {
    ".": {
      "svelte": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./Workbook.svelte": {
      "svelte": "./src/Workbook.svelte"
    },
    "./WorkbookBlock.svelte": {
      "svelte": "./src/WorkbookBlock.svelte"
    },
    "./CitationReport.svelte": {
      "svelte": "./src/CitationReport.svelte"
    },
    "./blockRegistry": {
      "svelte": "./src/blockRegistry.ts",
      "types": "./src/blockRegistry.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./wasmBridge": {
      "types": "./src/wasmBridge.ts",
      "default": "./src/wasmBridge.ts"
    },
    "./blocks/*": {
      "svelte": "./src/blocks/*"
    },
    "./workbookContext": {
      "svelte": "./src/workbookContext.ts",
      "types": "./src/workbookContext.ts"
    }
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "svelte": "^5.0.0",
    "convex-svelte": "*",
    "@deck.gl/aggregation-layers": "^9.0.0",
    "@deck.gl/core": "^9.0.0",
    "@deck.gl/layers": "^9.0.0",
    "@observablehq/plot": "^0.6.0",
    "cytoscape": "^3.0.0",
    "cytoscape-dagre": "^2.0.0",
    "echarts": "^5.0.0 || ^6.0.0",
    "maplibre-gl": "^4.0.0 || ^5.0.0",
    "mermaid": "^11.0.0",
    "plotly.js-dist-min": "^2.0.0 || ^3.0.0",
    "three": "^0.160.0 || ^0.170.0 || ^0.180.0"
  },
  "peerDependenciesMeta": {
    "convex-svelte": { "optional": true },
    "@deck.gl/aggregation-layers": { "optional": true },
    "@deck.gl/core": { "optional": true },
    "@deck.gl/layers": { "optional": true },
    "@observablehq/plot": { "optional": true },
    "cytoscape": { "optional": true },
    "cytoscape-dagre": { "optional": true },
    "echarts": { "optional": true },
    "maplibre-gl": { "optional": true },
    "mermaid": { "optional": true },
    "plotly.js-dist-min": { "optional": true },
    "three": { "optional": true }
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0"
  }
}
