#!/bin/sh
# Postinstall — runs as ROOT after the .pkg lays /Applications/Workbooks.app
# down. Two responsibilities:
#
#   1. Migrate users away from the old dual-app layout
#      (Workbooks.app shell-shim + /usr/local/bin/workbooksd
#      LaunchAgent). Kill any running daemon, bootout the
#      LaunchAgent, delete its plist + the bare binary.
#
#   2. Refresh Launch Services so /Applications/Workbooks.app's
#      .workbook.html UTI + public.html Alternate-rank are picked
#      up without requiring a logout.
#
# The new Workbooks.app spawns its own embedded daemon on first
# launch (detached via setsid so it survives Manager quit), so we
# do NOT install a LaunchAgent here. That's the whole point of the
# consolidation — one app, one binary path, no system-wide daemon
# supervisor.
#
# Idempotent: safe to re-run on upgrade. Best-effort throughout —
# we never fail an install because a legacy file we tried to clean
# up wasn't there.

set -e

CONSOLE_UID=$(stat -f%u /dev/console)
CONSOLE_USER=$(id -un "$CONSOLE_UID" 2>/dev/null || echo root)
CONSOLE_HOME=$(dscl . -read /Users/"$CONSOLE_USER" NFSHomeDirectory 2>/dev/null | awk '{print $2}')
[ -z "$CONSOLE_HOME" ] && CONSOLE_HOME="/Users/$CONSOLE_USER"

LEGACY_BIN="/usr/local/bin/workbooksd"
LEGACY_PLIST="$CONSOLE_HOME/Library/LaunchAgents/sh.workbooks.workbooksd.plist"

# 1a. Stop the legacy LaunchAgent if present. bootout is the modern
# way; failure usually means it wasn't loaded — fine.
launchctl bootout "gui/$CONSOLE_UID/sh.workbooks.workbooksd" >/dev/null 2>&1 || true

# 1b. Kill any straggler workbooksd process that wasn't owned by the
# LaunchAgent (e.g. a previous embedded-sidecar run that detached).
# pkill -f matches the full command line; tight enough that we won't
# clobber unrelated processes.
pkill -f /usr/local/bin/workbooksd >/dev/null 2>&1 || true

# 1c. Drop the legacy plist + bare binary. Don't error if they're
# already gone (clean-installs on fresh machines).
rm -f "$LEGACY_PLIST" || true
rm -f "$LEGACY_BIN" || true

# 1d. Stale runtime.json from the legacy daemon would point the new
# app at a dead port; strip it so the new app spawns fresh on first
# launch. The ledger.json sibling stays put — that's the user's
# workbook history, and it's compatible across versions.
RUNTIME_DIR="$CONSOLE_HOME/Library/Application Support/sh.workbooks.workbooksd"
rm -f "$RUNTIME_DIR/runtime.json" || true

# 2. Launch Services refresh. The .pkg overwrites
# /Applications/Workbooks.app, but LaunchServices caches the prior
# bundle's UTI declarations until something nudges it. -f forces
# re-registration of the bundle's CFBundleDocumentTypes +
# UTExportedTypeDeclarations.
LSREGISTER="/System/Library/Frameworks/CoreServices.framework/Versions/A/Frameworks/LaunchServices.framework/Versions/A/Support/lsregister"
if [ -x "$LSREGISTER" ]; then
  "$LSREGISTER" -f /Applications/Workbooks.app >/dev/null 2>&1 || true
fi

exit 0
