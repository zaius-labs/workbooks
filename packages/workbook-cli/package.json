{
  "name": "@work.books/cli",
  "version": "0.2.3",
  "description": "Build tool for workbooks — compiles a multi-file source tree into a single, self-contained .workbook.html.",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/zaius-labs/workbooks.git",
    "directory": "packages/workbook-cli"
  },
  "homepage": "https://github.com/zaius-labs/workbooks",
  "keywords": [
    "workbook",
    "build",
    "vite",
    "single-file",
    "portable"
  ],
  "bin": {
    "workbook": "./bin/workbook.mjs"
  },
  "exports": {
    ".": "./src/index.mjs",
    "./vite": "./src/plugins/index.mjs"
  },
  "files": [
    "bin",
    "src",
    "templates",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "unist-util-visit": "^5.0.0",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.0.0"
  },
  "peerDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "mdsvex": "^0.12.0",
    "svelte": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@sveltejs/vite-plugin-svelte": {
      "optional": true
    },
    "mdsvex": {
      "optional": true
    },
    "svelte": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
